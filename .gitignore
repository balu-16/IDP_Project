# -----------------------------
# Workspace-level ignores
# -----------------------------

# OS / editor noise
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json
*.swp
*.swo

# Generic env/secrets
.env
.env.*
!.env.example
*.local

# Logs and runtime files
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Python caches / envs (any package)
**/__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.venv/
venv/

# Node / frontend artifacts (any package)
**/node_modules/
**/dist/
**/dist-ssr/
**/.next/
**/.nuxt/
**/.turbo/
**/.cache/

# Build outputs / package artifacts
build/
tmp/
*.pid

# Local vector DB/runtime data
chroma_db/
backend/chroma_db/
backend/uploads/

